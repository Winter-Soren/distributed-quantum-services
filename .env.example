# Docker + Caddy deployment settings

# Local:
# CADDY_SITE_ADDRESS=http://localhost
#
# EC2 with TLS:
# CADDY_SITE_ADDRESS=quantum.example.com
CADDY_SITE_ADDRESS=http://localhost

# Leave this empty unless you turn on QC_API__ENABLE_AUTH.
QUANTUM_BACKEND_API_KEY=

# Optional backend overrides for the Compose stack.
QC_API__ENABLE_AUTH=false
QC_DATABASE__PATH=/var/lib/quantum-coordinator/quantum_coordinator.db
QC_LIBP2P__ENABLED=true
