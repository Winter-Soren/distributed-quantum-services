# Example backend-v2 runtime configuration.
# Copy this file to `.env`, then replace placeholder credentials with your own.
#
# Bool parsing in backend-v2:
# `1`, `true`, `yes`, `on` => true
# anything else => false

# -----------------------------------------------------------------------------
# App and API
# -----------------------------------------------------------------------------

# Typical values: `development`, `staging`, `production`, `test`
QB2_ENVIRONMENT=development

# Human-readable service name surfaced in logs and health endpoints.
QB2_SERVICE_NAME=quantum-backend-v2

# API bind host and port.
QB2_API_HOST=0.0.0.0
QB2_API_PORT=8081

# Standard Python log levels: `DEBUG`, `INFO`, `WARNING`, `ERROR`, `CRITICAL`
QB2_LOG_LEVEL=INFO

# `true` => structured JSON logs, `false` => simpler local logs
QB2_JSON_LOGS=true

# `false` disables auth for local development only.
QB2_AUTH_REQUIRED=false

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------

# Allowed values:
# `local` => use QB2_POSTGRES_LOCAL_DSN
# `neon`  => use QB2_POSTGRES_NEON_POOLED_DSN / QB2_POSTGRES_NEON_DIRECT_DSN
QB2_POSTGRES_TARGET=local

# Local DSN format:
# `postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME`
# Source: your local Postgres install / Docker / cloud proxy.
QB2_POSTGRES_LOCAL_DSN=postgresql+asyncpg://postgres:password@127.0.0.1:5432/qds

# Neon pooled DSN for application traffic.
# Source: Neon Dashboard -> Project -> Connection Details -> Pooled connection.
QB2_POSTGRES_NEON_POOLED_DSN=postgresql+asyncpg://user:password@your-neon-pooler-host/neondb?sslmode=require

# Neon direct DSN for migrations and admin tooling.
# Source: Neon Dashboard -> Project -> Connection Details -> Direct connection.
QB2_POSTGRES_NEON_DIRECT_DSN=

# Logical database label shown in readiness output.
QB2_POSTGRES_DATABASE=qds

QB2_POSTGRES_ECHO=false
QB2_POSTGRES_POOL_PRE_PING=true

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------

# Allowed values:
# `local`  => use QB2_MONGODB_LOCAL_URI
# `remote` => use QB2_MONGODB_REMOTE_URI
QB2_MONGODB_TARGET=local

# Local URI examples:
# `mongodb://127.0.0.1:27017`
# `mongodb://USER:PASSWORD@127.0.0.1:27017/?authSource=admin`
QB2_MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017

# Atlas URI usually starts with `mongodb+srv://`.
# Source: MongoDB Atlas -> Cluster -> Connect -> Drivers.
QB2_MONGODB_REMOTE_URI=

# Logical database name inside MongoDB / Atlas.
QB2_MONGODB_DATABASE=qds

QB2_MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Local peer log
# -----------------------------------------------------------------------------

# Where append-only peer log files are stored on disk.
QB2_PEER_LOG_DIR=./quantum-backend-v2/peer-logs

# Stable local folder name for the peer log.
QB2_PEER_ID=qb2-local-peer

QB2_PEER_LOG_FSYNC=true

# -----------------------------------------------------------------------------
# Libp2p
# -----------------------------------------------------------------------------

# Enable/disable the real py-libp2p runtime.
QB2_LIBP2P_ENABLED=true

# Stable seed label used to derive the peer identity keypair.
QB2_LIBP2P_PEER_ID=qb2-local-peer

# Comma-separated listen multiaddrs.
# Example:
# `/ip4/0.0.0.0/tcp/4011`
QB2_LIBP2P_LISTEN_MULTIADDRS=/ip4/0.0.0.0/tcp/4011

# Optional comma-separated dialable multiaddrs to advertise to other peers.
# Use this when the bind address is not the same address peers should dial.
# Example:
# `/ip4/127.0.0.1/tcp/4011`
QB2_LIBP2P_ADVERTISE_MULTIADDRS=

# Comma-separated bootstrap peer multiaddrs, usually ending with `/p2p/<peer_id>`.
# Example:
# `/ip4/127.0.0.1/tcp/4011/p2p/12D3KooW...`
QB2_LIBP2P_BOOTSTRAP_PEERS=

# Peers must share the same namespace to discover each other.
QB2_LIBP2P_RENDEZVOUS_NAMESPACE=quantum-backend-v2

# Local sqlite peerstore path for py-libp2p.
# `make run-clean` removes this file before startup.
QB2_LIBP2P_PEERSTORE_PATH=./quantum-backend-v2/libp2p/peerstore.sqlite3

# `true` enables actual socket listeners; set this when using the local
# distributed dev fabric below.
QB2_LIBP2P_ACTIVATE_LISTENERS=true

# Extra local worker peers started alongside the main bootstrap/coordinator
# peer. Set this to `4` for the recommended `1 + 4` local swarm.
QB2_LIBP2P_DEV_SERVICE_PEER_COUNT=4

# Base TCP port for the embedded worker peers when they are enabled.
QB2_LIBP2P_DEV_SERVICE_BASE_PORT=4021
