{
  "info": {
    "_postman_id": "3ef3101b-a50e-4b77-8f66-8da2b4fe1d3d",
    "name": "Distributed Quantum Services",
    "description": "Import this collection into Postman to exercise the FastAPI coordinator over real HTTP endpoints.\n\nDefault base URL assumes the local demo server is running on port 8080.\n\nWebSocket endpoint for manual testing in Postman WebSocket client:\nws://127.0.0.1:8080/api/v1/jobs/{{jobId}}/ws",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8080"
    },
    {
      "key": "apiKey",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "failedJobId",
      "value": ""
    },
    {
      "key": "planId",
      "value": ""
    },
    {
      "key": "nodeId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/health",
            "description": "Basic liveness probe for the coordinator."
          }
        },
        {
          "name": "List Services",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const payload = pm.response.json();",
                  "if (Array.isArray(payload) && payload.length > 0 && payload[0].node_id) {",
                  "  pm.collectionVariables.set('nodeId', payload[0].node_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/services",
            "description": "Lists currently advertised libp2p-backed service nodes and stores the first node_id into {{nodeId}}."
          }
        },
        {
          "name": "Fidelity Metrics For Stored Node",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/metrics/fidelity/{{nodeId}}",
            "description": "Fetches fidelity metrics for the node captured from the service list request."
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Submit Multi-Step Circuit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const payload = pm.response.json();",
                  "if (payload.job_id) {",
                  "  pm.collectionVariables.set('jobId', payload.job_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"circuit\": \"OPENQASM 3;\\nqubit[2] q;\\nbit[1] c;\\nbell_pair q[0], q[1];\\ncnot q[0], q[1];\\ncz q[0], q[1];\\nteleport q[0], q[1];\\nsyndrome_extraction q[0];\\ndistillation q[1];\\nmeasure q[0] -> c[0];\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/circuits/submit",
            "description": "End-to-end success case using all major gate/service types. Stores the returned job_id into {{jobId}}."
          }
        },
        {
          "name": "Get Job Status For Stored Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const payload = pm.response.json();",
                  "if (payload.plan_id) {",
                  "  pm.collectionVariables.set('planId', payload.plan_id);",
                  "}",
                  "if (payload.status) {",
                  "  pm.collectionVariables.set('lastJobStatus', payload.status);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}",
            "description": "Poll this after submitting a valid job. Stores the resulting plan_id into {{planId}} once the job has compiled."
          }
        },
        {
          "name": "Get Execution Plan For Stored Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/plans/{{planId}}",
            "description": "Returns the compiled fragment graph and candidate assignments for the latest successful job."
          }
        },
        {
          "name": "Submit Single-Gate Circuit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"circuit\": \"OPENQASM 2.0;\\nqreg q[2];\\ncx q[0], q[1];\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/circuits/submit",
            "description": "Minimal happy-path request for quick smoke checks."
          }
        },
        {
          "name": "Submit Unsupported Circuit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const payload = pm.response.json();",
                  "if (payload.job_id) {",
                  "  pm.collectionVariables.set('failedJobId', payload.job_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"circuit\": \"OPENQASM 3;\\nqubit[1] q;\\nh q[0];\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/circuits/submit",
            "description": "Failure example. The job should eventually become FAILED with error: Unsupported gate/service 'h'."
          }
        },
        {
          "name": "Get Failed Job Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/v1/jobs/{{failedJobId}}",
            "description": "Poll this after submitting the unsupported circuit to confirm the failure path and returned error."
          }
        }
      ]
    }
  ]
}
